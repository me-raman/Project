# Server Configuration
NODE_ENV=production
PORT=3000

# Database - MongoDB Atlas (REQUIRED for production)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/pharmatrace?retryWrites=true&w=majority

# Authentication (REQUIRED - generate a new secret for production)
JWT_SECRET=<generate-a-secure-64-char-random-string>
JWT_EXPIRY=5d

# CORS - Frontend URL on Vercel (REQUIRED)
FRONTEND_URL=https://your-app.vercel.app

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# OTP Configuration
OTP_EXPIRY_MINUTES=5
